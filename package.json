{
  "name": "playhead",
  "productName": "Playhead",
  "version": "0.1.0",
  "description": "Local-first desktop music player prototype with waveform playback.",
  "author": "Edin",
  "license": "MIT",
  "private": false,
  "packageManager": "pnpm@10.32.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && electron-vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "dist": "pnpm dist:mac",
    "dist:mac": "pnpm build && electron-builder --mac --publish never",
    "preview": "electron-vite preview"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron-winstaller",
      "esbuild",
      "protobufjs"
    ]
  },
  "build": {
    "appId": "com.playhead.app",
    "productName": "Playhead",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/playhead-icon.png",
        "to": "playhead-icon.png"
      }
    ],
    "mac": {
      "icon": "resources/playhead.icns",
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@opentelemetry/exporter-logs-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.217.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "ieee754": "^1.2.1",
    "lucide-react": "^1.14.0",
    "music-metadata": "^11.12.3",
    "node-taglib-sharp": "^6.0.3",
    "react": "latest",
    "react-dom": "latest",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "wavesurfer.js": "^7.12.6"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "latest",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "latest",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "latest",
    "electron-builder": "^26.8.1",
    "electron-vite": "latest",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
