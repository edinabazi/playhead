{
  "name": "playhead-integrations-broker",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-29",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "SOUNDCLOUD_REDIRECT_URI": "playhead://soundcloud/callback"
  }
}
